          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.Net;
using System.IO;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
#endregion

namespace ST_HealthCheckAPI
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain :
        Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            try
            {
                // Read SSIS Variables
                string baseUrl =
                    Dts.Variables["User::APIBaseURL"].Value.ToString();

                string endpoint =
                    Dts.Variables["User::HealthAPI"].Value.ToString();

                // Build URL
                string url = baseUrl + endpoint;

                // Create HTTP Request
                HttpWebRequest request =
                    (HttpWebRequest)WebRequest.Create(url);

                request.Method = "GET";

                // Get Response
                using (HttpWebResponse response =
                    (HttpWebResponse)request.GetResponse())
                {
                    using (StreamReader reader =
                        new StreamReader(response.GetResponseStream()))
                    {
                        string result = reader.ReadToEnd();

                        // Log response in SSIS Output window
                        bool fireAgain = false;

                        Dts.Events.FireInformation(
                            0,
                            "Health Check API",
                            "API Response: " + result,
                            "",
                            0,
                            ref fireAgain
                        );

                        // Validate API Status
                        if (result.Contains("\"status\"") && result.Contains("\"UP\""))
                        {
                            Dts.Events.FireInformation(
                                0,
                                "Health Check API",
                                "Source System is UP.",
                                "",
                                0,
                                ref fireAgain
                            );

                            Dts.TaskResult =
                                (int)ScriptResults.Success;
                        }
                        else
                        {
                            Dts.Events.FireError(
                                0,
                                "Health Check API",
                                "Source System is NOT UP.",
                                "",
                                0
                            );

                            Dts.TaskResult =
                                (int)ScriptResults.Failure;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                // Log Error
                Dts.Events.FireError(
                    0,
                    "Health Check API",
                    ex.Message,
                    "",
                    0
                );

                Dts.TaskResult =
                    (int)ScriptResults.Failure;
            }
        }

        #region ScriptResults declaration
        enum ScriptResults
        {
            Success = DTSExecResult.Success,
            Failure = DTSExecResult.Failure
        };
        #endregion
    }
}]]></ProjectItem>
