    <DTS:Executable
      DTS:refId="Package\Validate Policies"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6489587B-F937-4CCA-B9C5-851BC40F5A12}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Validate Policies"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DC2EE7E8-A7E3-443F-B8B8-88393A62339F}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.Rej_Policies&#xA;(&#xA;    PolicyID,&#xA;    PolicyNumber,&#xA;    CustomerName,&#xA;    PolicyType,&#xA;    Premium,&#xA;    EffectiveDate,&#xA;    ExpiryDate,&#xA;    State,&#xA;    RejectReason&#xA;)&#xA;SELECT&#xA;    PolicyID,&#xA;    PolicyNumber,&#xA;    CustomerName,&#xA;    PolicyType,&#xA;    Premium,&#xA;    EffectiveDate,&#xA;    ExpiryDate,&#xA;    State,&#xA;    CASE&#xA;        WHEN Premium &lt;= 0 THEN 'Invalid Premium'&#xA;        WHEN ExpiryDate &lt; EffectiveDate THEN 'Expiry Date earlier than Effective Date'&#xA;        WHEN PolicyNumber IS NULL OR LTRIM(RTRIM(PolicyNumber)) = '' THEN 'Missing Policy Number'&#xA;        WHEN CustomerName IS NULL OR LTRIM(RTRIM(CustomerName)) = '' THEN 'Missing Customer Name'&#xA;        ELSE 'Unknown Validation Error'&#xA;    END&#xA;FROM dbo.Stg_Policies&#xA;WHERE Premium &lt;= 0&#xA;   OR ExpiryDate &lt; EffectiveDate&#xA;   OR PolicyNumber IS NULL&#xA;   OR LTRIM(RTRIM(PolicyNumber)) = ''&#xA;   OR CustomerName IS NULL&#xA;   OR LTRIM(RTRIM(CustomerName)) = ''" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
