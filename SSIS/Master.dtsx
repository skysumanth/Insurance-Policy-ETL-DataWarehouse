          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.IO;
using System.Net;
using Microsoft.SqlServer.Dts.Runtime;
#endregion

namespace ST_ExtractPoliciesAPI
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain :
        Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            bool fireAgain = false;

            try
            {
                string baseUrl =
                    Dts.Variables["User::APIBaseURL"].Value.ToString();

                string endpoint =
                    Dts.Variables["User::PoliciesAPI"].Value.ToString();

                string jsonFilePath =
                    Dts.Variables["User::JSONFilePath"].Value.ToString();

                string url = baseUrl + endpoint;

                HttpWebRequest request =
                    (HttpWebRequest)WebRequest.Create(url);

                request.Method = "GET";

                using (HttpWebResponse response =
                    (HttpWebResponse)request.GetResponse())
                {
                    using (StreamReader reader =
                        new StreamReader(response.GetResponseStream()))
                    {
                        string json = reader.ReadToEnd();

                        // Save JSON to file
                        File.WriteAllText(jsonFilePath, json);

                        Dts.Events.FireInformation(
                            0,
                            "Extract Policies API",
                            "Policies JSON saved to: " + jsonFilePath,
                            "",
                            0,
                            ref fireAgain
                        );

                        Dts.TaskResult =
                            (int)ScriptResults.Success;
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(
                    0,
                    "Extract Policies API",
                    ex.Message,
                    "",
                    0
                );

                Dts.TaskResult =
                    (int)ScriptResults.Failure;
            }
        }

        enum ScriptResults
        {
            Success = DTSExecResult.Success,
            Failure = DTSExecResult.Failure
        }
    }
}]]></ProjectItem>
