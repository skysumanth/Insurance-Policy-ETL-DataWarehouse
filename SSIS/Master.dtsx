          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using Microsoft.SqlServer.Dts.Runtime;
#endregion

namespace ST_SetExtractCount
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain :
        Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            try
            {
                // Number of records extracted from the API
                // Currently hardcoded based on our test data
                Dts.Variables["User::RecordsExtracted"].Value = 3;

                bool fireAgain = false;

                Dts.Events.FireInformation(
                    0,
                    "Set Extract Count",
                    "Records Extracted set to 3.",
                    "",
                    0,
                    ref fireAgain
                );

                Dts.TaskResult = (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(
                    0,
                    "Set Extract Count",
                    ex.Message,
                    "",
                    0
                );

                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        enum ScriptResults
        {
            Success = DTSExecResult.Success,
            Failure = DTSExecResult.Failure
        };
    }
}]]></ProjectItem>
