      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DC2EE7E8-A7E3-443F-B8B8-88393A62339F}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.DimPolicyType&#xA;(&#xA;    PolicyTypeName&#xA;)&#xA;SELECT DISTINCT&#xA;    PolicyType&#xA;FROM dbo.Stg_Policies S&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM dbo.DimPolicyType D&#xA;    WHERE D.PolicyTypeName = S.PolicyType&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load DimState"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{337516F1-CD4F-4018-8222-F8FB1ACE2AFF}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load DimState"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DC2EE7E8-A7E3-443F-B8B8-88393A62339F}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.DimState&#xA;(&#xA;    StateName&#xA;)&#xA;SELECT DISTINCT&#xA;    State&#xA;FROM dbo.Stg_Policies S&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM dbo.DimState D&#xA;    WHERE D.StateName = S.State&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load FactPolicy"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{85C7A2E3-54E9-4708-B7C5-C5FA95C48648}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load FactPolicy"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{DC2EE7E8-A7E3-443F-B8B8-88393A62339F}"
          SQLTask:SqlStatementSource="INSERT INTO dbo.FactPolicy&#xA;(&#xA;    PolicyID,&#xA;    PolicyNumber,&#xA;    PolicyTypeKey,&#xA;    StateKey,&#xA;    Premium,&#xA;    EffectiveDate,&#xA;    ExpiryDate,&#xA;    CreatedDate&#xA;)&#xA;SELECT&#xA;    S.PolicyID,&#xA;    S.PolicyNumber,&#xA;    PT.PolicyTypeKey,&#xA;    DS.StateKey,&#xA;    S.Premium,&#xA;    S.EffectiveDate,&#xA;    S.ExpiryDate,&#xA;    S.CreatedDate&#xA;FROM dbo.Stg_Policies S&#xA;INNER JOIN dbo.DimPolicyType PT&#xA;    ON S.PolicyType = PT.PolicyTypeName&#xA;INNER JOIN dbo.DimState DS&#xA;    ON S.State = DS.StateName&#xA;WHERE NOT EXISTS&#xA;(&#xA;    SELECT 1&#xA;    FROM dbo.FactPolicy F&#xA;    WHERE F.PolicyID = S.PolicyID&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
