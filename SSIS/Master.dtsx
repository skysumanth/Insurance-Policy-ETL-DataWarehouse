          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Namespaces
using System;
using System.IO;
using System.Data.SqlClient;
using System.Collections.Generic;
using System.Web.Script.Serialization;
using Microsoft.SqlServer.Dts.Runtime;
#endregion

namespace ST_LoadPolicies
{
    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain :
        Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {
        public void Main()
        {
            bool fireAgain = false;

            try
            {
                string jsonFilePath =
                    Dts.Variables["User::JSONFilePath"].Value.ToString();

                string json =
                    File.ReadAllText(jsonFilePath);

                JavaScriptSerializer serializer =
                    new JavaScriptSerializer();

                var policies =
                    serializer.Deserialize<List<Dictionary<string, object>>>(json);

                string connectionString =
                    @"Server=KMG-GGN-353\MSSQLSERVER01;
                      Database=InsurancePortalDB;
                      Trusted_Connection=True;";

                using (SqlConnection conn =
                    new SqlConnection(connectionString))
                {
                    conn.Open();

                    // Clear staging table
                    SqlCommand truncate =
                        new SqlCommand(
                            "TRUNCATE TABLE dbo.Stg_Policies",
                            conn);

                    truncate.ExecuteNonQuery();

                    foreach (var policy in policies)
                    {
                        SqlCommand cmd =
                            new SqlCommand(@"
INSERT INTO dbo.Stg_Policies
(
    PolicyID,
    PolicyNumber,
    CustomerName,
    PolicyType,
    Premium,
    EffectiveDate,
    ExpiryDate,
    State,
    CreatedDate,
    ModifiedDate
)
VALUES
(
    @PolicyID,
    @PolicyNumber,
    @CustomerName,
    @PolicyType,
    @Premium,
    @EffectiveDate,
    @ExpiryDate,
    @State,
    @CreatedDate,
    @ModifiedDate
)", conn);

                        cmd.Parameters.AddWithValue(
    "@PolicyID",
    Convert.ToInt32(policy["PolicyID"])
);

                        cmd.Parameters.AddWithValue(
                            "@PolicyNumber",
                            policy["PolicyNumber"].ToString()
                        );

                        cmd.Parameters.AddWithValue(
                            "@CustomerName",
                            policy["CustomerName"].ToString()
                        );

                        cmd.Parameters.AddWithValue(
                            "@PolicyType",
                            policy["PolicyType"].ToString()
                        );

                        cmd.Parameters.AddWithValue(
                            "@Premium",
                            Convert.ToDecimal(policy["Premium"].ToString())
                        );

                        cmd.Parameters.AddWithValue(
                            "@EffectiveDate",
                            DateTime.Parse(policy["EffectiveDate"].ToString())
                        );

                        cmd.Parameters.AddWithValue(
                            "@ExpiryDate",
                            DateTime.Parse(policy["ExpiryDate"].ToString())
                        );

                        cmd.Parameters.AddWithValue(
                            "@State",
                            policy["State"].ToString()
                        );

                        // CreatedDate
                        if (policy["CreatedDate"] == null)
                        {
                            cmd.Parameters.AddWithValue(
                                "@CreatedDate",
                                DBNull.Value
                            );
                        }
                        else
                        {
                            cmd.Parameters.AddWithValue(
                                "@CreatedDate",
                                DateTime.Parse(policy["CreatedDate"].ToString())
                            );
                        }

                        // ModifiedDate
                        if (policy["ModifiedDate"] == null)
                        {
                            cmd.Parameters.AddWithValue(
                                "@ModifiedDate",
                                DBNull.Value
                            );
                        }
                        else
                        {
                            cmd.Parameters.AddWithValue(
                                "@ModifiedDate",
                                DateTime.Parse(policy["ModifiedDate"].ToString())
                            );
                        }

                        cmd.ExecuteNonQuery();
                    }

                    conn.Close();
                }

                Dts.Events.FireInformation(
                    0,
                    "Load Policies",
                    policies.Count + " records loaded into Stg_Policies.",
                    "",
                    0,
                    ref fireAgain);

                Dts.TaskResult =
                    (int)ScriptResults.Success;
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(
                    0,
                    "Load Policies",
                    ex.ToString(),
                    "",
                    0);

                Dts.TaskResult =
                    (int)ScriptResults.Failure;
            }
        }

        enum ScriptResults
        {
            Success = DTSExecResult.Success,
            Failure = DTSExecResult.Failure
        }
    }
}]]></ProjectItem>
